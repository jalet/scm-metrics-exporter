{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "scm-metrics-exporter values",
    "type": "object",
    "properties": {
        "affinity": {
            "type": "object"
        },
        "crds": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "keep": {
                    "type": "boolean"
                }
            }
        },
        "exporterImage": {
            "type": "object",
            "properties": {
                "repository": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            }
        },
        "fullnameOverride": {
            "type": "string"
        },
        "global": {
            "type": "object"
        },
        "image": {
            "type": "object",
            "properties": {
                "digest": {
                    "type": "string"
                },
                "pullPolicy": {
                    "type": "string"
                },
                "repository": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            }
        },
        "imagePullSecrets": {
            "type": "array"
        },
        "leaderElection": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                }
            }
        },
        "metrics": {
            "type": "object",
