                        },
                        "labels": {
                            "type": "object"
                        },
                        "metricRelabelings": {
                            "type": "array"
                        },
                        "relabelings": {
                            "type": "array"
                        },
                        "scrapeTimeout": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "podAnnotations": {
            "type": "object"
        },
        "podSecurityContext": {
            "type": "object",
            "properties": {
                "runAsNonRoot": {
                    "type": "boolean"
