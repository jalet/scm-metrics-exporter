        "tolerations": {
            "type": "array"
        },
        "topologySpreadConstraints": {
            "type": "array"
        },
        "valkey": {
            "type": "object",
            "properties": {
                "deploy": {
                    "type": "boolean"
                },
                "image": {
                    "type": "string"
                },
                "storage": {
                    "type": "string"
                }
            }
        }
    },
    "additionalProperties": false
}
